{
  "rules": {

    "counters": {
      "lastRegistrationNumber": {
        ".read": true,
        ".write": true
      }
    },

    "registrations": {
      "$emailKey": {
        ".read": true,
        ".write": "!data.exists() || data.child('participantCount').val() < 5"
      }
    },

    "participants": {
      "$regNum": {
        ".read": true,
        ".write": true
      }
    },

    "dashboard": {
      "summary": {
        ".read": true,
        ".write": true
      }
    },

    "audit": {
      ".read": false,
      ".write": true
    },

    "volunteers": {
      ".read": false,
      ".write": false
    },

    "incidents": {
      ".read": false,
      ".write": false
    }
  }
}
